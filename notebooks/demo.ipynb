    "## 3. Preprocessing Demo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create sample image\n",
    "sample_image = np.random.randn(512, 512) * 30 + 100\n",
    "sample_image = np.clip(sample_image, 0, 255).astype(np.uint8)\n",
    "\n",
    "preprocessor = ImagePreprocessor()\n",
    "preprocessed = preprocessor.preprocess(sample_image)\n",
    "\n",
    "print(f'Original shape: {sample_image.shape}')\n",
    "print(f'Preprocessed shape: {preprocessed.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Feature Extraction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize feature extractor\n",
    "extractor = CNNFeatureExtractor(model_name='resnet50', device='cpu')\n",
    "\n",
    "# Extract features\n",
    "features = extractor.extract_features(preprocessed)\n",
    "print(f'Feature vector shape: {features.shape}')\n",
    "print(f'First 10 features: {features[:10]}')"
   ]
  },
